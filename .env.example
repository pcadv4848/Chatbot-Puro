# ============================================
# ChatBot Puro — Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores
# Ou execute: bash deploy/setup.sh (gera automaticamente)

# ── App ──
DEBUG=false
PORT=8000
# workers=1 é OBRIGATÓRIO com SQLite (multi-process corrompe o banco)
UVICORN_WORKERS=1
# URL pública do bot (usada para registrar webhook no OpenWA)
# Ex: https://bot.penidocastro.com.br ou http://187.77.235.249
APP_URL=http://localhost:8000

# ── Provider WhatsApp ──
WHATSAPP_PROVIDER=openwa

# ── WhatsApp via OpenWA ──
OPENWA_API_URL=http://127.0.0.1:2785/api
OPENWA_API_KEY=
OPENWA_SESSION_ID=chatbot-puro
WEBHOOK_VERIFY_TOKEN=PCADV

# ── DeepSeek (primário) ──
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Verboo (fallback) ──
VERBOO_API_KEY=
VERBOO_ENDPOINT=https://code.verboo.ai/router/v1
VERBOO_MODEL=verboo-pro

# ── Google Gemini (opcional) ──
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# ── Anthropic / Claude (opcional) ──
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Banco de Dados ──
# SQLite (local): sqlite+aiosqlite:///./data/chatbot.db
# PostgreSQL (produção): postgresql+asyncpg://user:pass@host:5432/dbname
# ATENÇÃO: SQLite requer UVICORN_WORKERS=1 (single process)
DATABASE_URL=sqlite+aiosqlite:///./data/chatbot.db

# ── Advogado Responsável ──
# ADVOGADO_NOME=Penido Castro
# ADVOGADO_EMAIL=
# ADVOGADO_WHATSAPP=

# ── Segurança ──
# Chave AES-256 para criptografar dados sensíveis (32 bytes em hex)
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Ou execute: bash deploy/setup.sh (gera automaticamente)
ENCRYPT_KEY=

# ── CORS ──
# Em produção, restrinja ao domínio do admin panel
CORS_ORIGINS=*

# ── Admin WhatsApp ──
# Número autorizado a usar comandos administrativos (RESETAR., BOT., HUMANO., STATUS.)
ADMIN_WHATSAPP=557193589436
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# ── Lembretes ──
REMINDER_COOLDOWN_DAYS=3
REMINDER_MAX_COUNT=2
REMINDER_INTERVAL_HOURS=6

# ── Limites do Sistema ──
MAX_OCR_RETRIES=3
SESSION_TIMEOUT_MINUTES=60
SESSION_ARCHIVE_DAYS=30

# ── Retry / Tolerância a falhas ──
# RETRY_MAX_ATTEMPTS=3
# RETRY_BASE_DELAY=1.0
# RETRY_MAX_DELAY=30.0

# ── Rate limiting ──
# RATE_LIMIT_WEBHOOK=10/minute
