# ── ChatBot Puro — Produção (Servidor Próprio) ──
# Copie para /home/user/chatbot-puro/.env e edite as credenciais

DEBUG=false
PORT=8000
# workers=1 é OBRIGATÓRIO com SQLite (multi-process corrompe o banco)
UVICORN_WORKERS=1
# URL pública do bot (usada para registrar webhook no OpenWA)
# Ex: https://bot.seudominio.com.br ou http://SEU_IP_AQUI
APP_URL=http://SEU_IP_AQUI

# ── Provider WhatsApp ──
WHATSAPP_PROVIDER=openwa

# ── OpenWA (fork rodando na mesma máquina) ──
# Se porta 2785 estiver ocupada, mude a porta no OpenWA e aqui
OPENWA_API_URL=http://127.0.0.1:2785/api
OPENWA_API_KEY=COLOQUE_SUA_API_KEY_AQUI
OPENWA_SESSION_ID=chatbot-puro
WEBHOOK_VERIFY_TOKEN=PCADV

# ── DeepSeek ──
DEEPSEEK_API_KEY=sk-colocar-chave-aqui
DEEPSEEK_MODEL=deepseek-chat

# ── Banco (SQLite — suficiente para single-server) ──
DATABASE_URL=sqlite+aiosqlite:///./data/chatbot.db

# ── Admin WhatsApp ──
# Número do advogado que pode usar comandos: RESETAR., BOT., HUMANO., STATUS.
ADMIN_WHATSAPP=557193589436

# ── Segurança (32 bytes hex) ──
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# Ou execute: bash deploy/setup.sh para gerar automaticamente
ENCRYPT_KEY=

# ── Lembretes ──
REMINDER_COOLDOWN_DAYS=3
REMINDER_MAX_COUNT=2
REMINDER_INTERVAL_HOURS=6

# ── Limites ──
MAX_OCR_RETRIES=3
SESSION_TIMEOUT_MINUTES=60
SESSION_ARCHIVE_DAYS=30
