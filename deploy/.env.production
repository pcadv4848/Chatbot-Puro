# ── ChatBot Puro — Produção (Servidor Próprio) ──
# Copie para /home/penido-castro-bot/chatbot-puro/.env

DEBUG=false
PORT=8000
UVICORN_WORKERS=1
APP_URL=http://187.77.235.249

# ── Provider WhatsApp ──
WHATSAPP_PROVIDER=openwa

# ── OpenWA (fork rodando na mesma máquina) ──
OPENWA_API_URL=http://127.0.0.1:2785/api
OPENWA_API_KEY=PCADV48484848
OPENWA_SESSION_ID=chatbot-puro
WEBHOOK_VERIFY_TOKEN=PCADV

# ── DeepSeek ──
DEEPSEEK_API_KEY=sk-colocar-chave-aqui
DEEPSEEK_MODEL=deepseek-chat

# ── Banco (SQLite — suficiente para single-server) ──
# UVICORN_WORKERS=1 é OBRIGATÓRIO com SQLite (multi-process corrompe o banco)
DATABASE_URL=sqlite+aiosqlite:///./data/chatbot.db

# ── Admin WhatsApp ──
ADMIN_WHATSAPP=557193589436
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=

# ── Segurança (32 bytes hex) ──
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPT_KEY=

# ── Lembretes ──
REMINDER_COOLDOWN_DAYS=3
REMINDER_MAX_COUNT=2
REMINDER_INTERVAL_HOURS=6

# ── Limites ──
MAX_OCR_RETRIES=3
SESSION_TIMEOUT_MINUTES=60
SESSION_ARCHIVE_DAYS=30
